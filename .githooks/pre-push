#!/usr/bin/env sh
set -eu

repo_root="$(git rev-parse --show-toplevel)"

if command -v pwsh >/dev/null 2>&1; then
  pwsh -NoProfile -ExecutionPolicy Bypass -File "$repo_root/scripts/check.ps1"
elif command -v powershell.exe >/dev/null 2>&1; then
  powershell.exe -NoProfile -ExecutionPolicy Bypass -File "$repo_root/scripts/check.ps1"
else
  echo "PowerShell is required to run scripts/check.ps1 before push." >&2
  exit 1
fi
